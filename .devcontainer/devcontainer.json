{
  "name": "dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-${localEnv:DEVCONTAINER_SSH_PORT}",
  "build": {
    "dockerfile": "Dockerfile.host-user",
    "options": [
      "--platform=linux/amd64"
    ],
    "args": {
      "DEVCONTAINER_USERNAME": "${localEnv:USER}",
      "BASE_IMAGE": "${localEnv:BASE_IMAGE}"
    }
  },
  "runArgs": [
    "--name",
    "dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-${localEnv:DEVCONTAINER_SSH_PORT}"
  ],
  "remoteUser": "${localEnv:USER}",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/${localEnv:USER}/.ssh,type=bind,readonly=true",
    "source=${localEnv:HOME}/.claude,target=/home/${localEnv:USER}/.claude,type=bind",
    "source=${localEnv:HOME}/.codex,target=/home/${localEnv:USER}/.codex,type=bind",
    "source=${localEnv:HOME}/.gemini,target=/home/${localEnv:USER}/.gemini,type=bind",
    "source=${localEnv:HOME}/.local/state/dotfiles,target=/tmp/dotfiles-host-state,type=bind",
    "source=dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-mise-user,target=/home/${localEnv:USER}/.local/share/mise,type=volume"
  ],
  "containerEnv": {
    "MISE_ARCH": "x64",
    "MISE_OS": "linux",
    "MISE_TRUSTED_CONFIG_PATHS": "/usr/local/share/mise:/workspaces/dotfiles",
    "MISE_STRICT": "1"
  },
  "forwardAgent": true,
  "updateRemoteUserUID": false,
  "init": true,
  "initializeCommand": "mkdir -p ~/.ssh ~/.claude ~/.codex ~/.gemini ~/.local/state/dotfiles && touch ~/.ssh/config ~/.ssh/known_hosts ~/.ssh/authorized_keys",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "username": "${localEnv:USER}",
      "port": "4444",
      "startNow": true
    }
  },
  "appPort": ["${localEnv:DEVCONTAINER_SSH_PORT}:4444"],
  "forwardPorts": [4444],
  "onCreateCommand": "chezmoi init --apply --source=/workspaces/${localWorkspaceFolderBasename} --no-tty --force && sudo chown -R ${localEnv:USER}:${localEnv:USER} /home/${localEnv:USER}/.local/share/mise",
  "postCreateCommand": "scripts/devcontainer-smoke.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "mkhl.direnv"
      ]
    }
  }
}
