// Two-layer build hierarchy:
//
//   .devcontainer/Dockerfile            ← base image (CI-only per
//                                         feedback_base_image_ci_only.md).
//                                         Published to
//                                         ghcr.io/ray-manaloto/dotfiles-devcontainer:dev
//                                         by .github/workflows/ci.yml on
//                                         merges to main. Never build
//                                         locally.
//        │
//        ▼ (FROM ${BASE_IMAGE})
//
//   .devcontainer/Dockerfile.host-user  ← thin overlay (local build on
//                                         every `mise run up`). Adds
//                                         host-user rename + home staging.
//                                         ≤89 lines enforced by
//                                         hk.pkl:dockerfile_host_user_thin_overlay.
//
// BASE_IMAGE default comes from mise.toml [tasks.up].env. Override
// per-clone via mise.local.toml (see mise.local.toml.example).
//
// ===============================================================
// TWO independent SSH requirements, TWO mechanisms:
//
// (R1) INBOUND shell: `ssh ${USER}@localhost -p 4444` from Mac host
//      opens a shell into the container. Provided by:
//      - `features.ghcr.io/devcontainers/features/sshd` — installs
//        openssh-server. NOTE: the feature's `port`/`username`/`startNow`
//        options are silently dropped (see research report); sshd
//        listens on its hardcoded **2222** internally. External port is
//        `${DEVCONTAINER_SSH_PORT}` (default 4444) via `appPort`.
//      - `postCreateCommand` copies the host user's authorized keys
//        (pre-written by `dotfiles-setup docker initialize-host` on the
//        host from `ssh-add -L`) into `~/.ssh/authorized_keys` so the
//        container sshd can authenticate the Mac user.
//
// (R2) OUTBOUND agent: `ssh -T git@github.com` inside the container
//      reaches the host's launchd SSH agent via Docker Desktop's
//      native `/run/host-services/ssh-auth.sock` magic socket,
//      bind-mounted into the container and pointed at by
//      `containerEnv.SSH_AUTH_SOCK`. The socket arrives as
//      root:root 0660; `postCreateCommand` chowns it to the container
//      user. No host-side or container-side proxy required.
//      Runtime pin: Docker Desktop only — Colima has no equivalent
//      (`abiosoft/colima#1330`, `#942`); deferred follow-up #78.
//
// Research + rationale:
//   .omc/research/research-20260409c-dockerdesktop-ssh/report.md
//
// ===============================================================
// (S1) SECRETS injection via Doppler:
//
// `initializeCommand` (host-side) runs `doppler secrets download`
// to write a KEY=VALUE env file to the staging area
// (~/.local/state/dotfiles/doppler.env). `runArgs --env-file`
// injects all secrets as container env vars at creation time.
// No doppler CLI needed inside the container.
//
// Doppler project/config defaults come from mise.toml [tasks.up].env
// (DOPPLER_PROJECT=dotfiles, DOPPLER_CONFIG=dev). Override per-clone
// via mise.local.toml. Future: migrate to mise-env-fnox integration
// with doppler provider inside the container (#83).
// ===============================================================
{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-${localEnv:DEVCONTAINER_WORKSPACE_HASH}-${localEnv:DEVCONTAINER_SSH_PORT}",
  "build": {
    "dockerfile": "Dockerfile.host-user",
    "options": ["--platform=linux/amd64/v2"],
    "args": {
      "DEVCONTAINER_USERNAME": "${localEnv:USER}",
      "BASE_IMAGE": "${localEnv:BASE_IMAGE}",
    },
  },
  "runArgs": [
    "--name",
    "dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-${localEnv:DEVCONTAINER_WORKSPACE_HASH}-${localEnv:DEVCONTAINER_SSH_PORT}",
    "--env-file",
    "${localEnv:HOME}/.local/state/dotfiles/doppler.env",
    "--platform=linux/amd64/v2",
  ],
  "remoteUser": "${localEnv:USER}",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "mounts": [
    "source=${localEnv:HOME}/.local/state/dotfiles,target=/tmp/dotfiles-host-state,type=bind",
    "source=/run/host-services/ssh-auth.sock,target=/run/host-services/ssh-auth.sock,type=bind",
    "source=dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-${localEnv:DEVCONTAINER_WORKSPACE_HASH}-home,target=/home/${localEnv:USER},type=volume",
  ],
  "containerEnv": {
    // ─ Platform hints ────────────────────────────────────────────────
    // Runtime visibility for user shells (e.g., when a user invokes
    // conda directly without going through mise). Also set in
    // .devcontainer/mise-system.toml [env] which applies during
    // build-time `mise install --system -y` (when containerEnv has not
    // yet been applied to the build process). Duplication is intentional
    // — the two windows do not overlap.
    "MISE_ARCH": "x86_64",
    "MISE_OS": "linux",
    "CONDA_SUBDIR": "linux-64",

    // ─ Config trust + discovery ──────────────────────────────────────
    // Trust ALL paths without prompting ("/" matches everything).
    // Required for non-interactive mise activation in user shells,
    // IDEs, and CI-equivalent jobs inside the container — no
    // `mise trust` prompt blocks. This OVERRIDES the narrower
    // build-time MISE_TRUSTED_CONFIG_PATHS=/usr/local/share/mise:/workspaces/dotfiles
    // set in Dockerfile ENV (line 62). Verified canonical mechanism per
    // mise docs (configuration.md MISE_TRUSTED_CONFIG_PATHS section).
    "MISE_TRUSTED_CONFIG_PATHS": "/",

    // Skip the host-shaped workspace mise.toml inside the container.
    // Its 46 user-tools are already provided by the system tree
    // (.devcontainer/mise-system.toml, baked into :dev). Without this
    // exclusion, mise would discover /workspaces/<basename>/mise.toml
    // via cwd-walking and — because auto_install=true is set in
    // user-overlay home/dot_config/mise/config.toml.tmpl — attempt to
    // install all 46 tools again into the user overlay, emitting
    // "WARN: not installed" for each. MISE_IGNORED_CONFIG_PATHS is the
    // path-axis opt-out (vs the older filename-axis MISE_OVERRIDE_CONFIG_FILENAMES,
    // which had the side-effect of blocking ALL `mise.toml` files
    // anywhere in the container). Verified jdx/mise@v2026.4.28 against
    // upstream HEAD: src/env.rs MISE_IGNORED_CONFIG_PATHS definition,
    // settings.toml [ignored_config_paths] section, src/config/mod.rs.
    "MISE_IGNORED_CONFIG_PATHS": "/workspaces/${localWorkspaceFolderBasename}/mise.toml",

    // Explicit system-config location. Per src/config/mod.rs
    // `system_config_files()`, MISE_SYSTEM_CONFIG_FILE short-circuits
    // all other system-config discovery, so this is the single source
    // of truth for "which file is the system config." Re-set here
    // alongside Dockerfile ENV so user-mise at runtime sees it
    // explicitly (defense-in-depth: even if Docker ENV inheritance
    // were skipped, containerEnv covers it).
    "MISE_SYSTEM_CONFIG_DIR": "/usr/local/share/mise",
    "MISE_SYSTEM_CONFIG_FILE": "/usr/local/share/mise/config.toml",

    // Per-user mise config — path templated to host user's home. This
    // OVERRIDES the build-time MISE_CONFIG_DIR=/usr/local/share/mise
    // set in Dockerfile ENV (build-time uses the system path so
    // `mise install --system -y` finds the system config; runtime uses
    // per-user path so each user has their own overlay at
    // ~/.config/mise/config.toml). The two values cover different
    // windows; the override is intentional.
    "MISE_GLOBAL_CONFIG_FILE": "/home/${localEnv:USER}/.config/mise/config.toml",
    "MISE_CONFIG_DIR": "/home/${localEnv:USER}/.config/mise",

    // ─ Runtime markers ───────────────────────────────────────────────
    // Container-environment marker for chezmoi templates and other
    // tooling that needs to discriminate "inside the devcontainer (not
    // the Mac host)." chezmoi.os == "linux" is the canonical built-in
    // check, but DEVCONTAINER=true is the explicit signal for the
    // mise-overlay gate in home/.chezmoi.toml.tmpl. See
    // feedback_devcontainer_only_mise_overlay.md (auto-memory).
    "DEVCONTAINER": "true",

    // Docker Desktop's native magic socket for SSH agent forwarding
    // (R2 outbound: `ssh -T git@github.com` inside the container reaches
    // the host's launchd SSH agent — no host-side proxy needed). The
    // socket is bind-mounted via `mounts` above; this env var points
    // tools at it. Docker-Desktop-only — Colima has no equivalent
    // (`abiosoft/colima#1330`, #942; deferred follow-up #78). See
    // .omc/research/research-20260409c-dockerdesktop-ssh/report.md.
    "SSH_AUTH_SOCK": "/run/host-services/ssh-auth.sock",
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {},
  },
  "appPort": ["${localEnv:DEVCONTAINER_SSH_PORT}:2222"],
  "forwardPorts": [2222],
  "updateRemoteUserUID": false,
  "init": true,
  "initializeCommand": "mkdir -p ~/.local/state/dotfiles && doppler secrets download --format docker --no-file --project \"${DOPPLER_PROJECT:-dotfiles}\" --config \"${DOPPLER_CONFIG:-dev}\" > ~/.local/state/dotfiles/doppler.env && [ -s ~/.local/state/dotfiles/doppler.env ] && uv run --project python dotfiles-setup docker initialize-host",
  "onCreateCommand": "bash /workspaces/${localWorkspaceFolderBasename}/.devcontainer/scripts/on-create.sh /workspaces/${localWorkspaceFolderBasename}",
  "postCreateCommand": "sudo chown ${localEnv:USER}:${localEnv:USER} /run/host-services/ssh-auth.sock && install -d -m 700 ~/.ssh && install -m 600 /tmp/dotfiles-host-state/authorized_keys ~/.ssh/authorized_keys && ssh-keyscan -t rsa,ecdsa,ed25519 github.com >> ~/.ssh/known_hosts && [ -s ~/.ssh/known_hosts ] && chmod 600 ~/.ssh/known_hosts && scripts/devcontainer-smoke.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
      ],
    },
  },
}
