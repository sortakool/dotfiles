// Two-layer build hierarchy:
//
//   .devcontainer/Dockerfile            ← base image (CI-only per
//                                         feedback_base_image_ci_only.md).
//                                         Published to
//                                         ghcr.io/ray-manaloto/dotfiles-devcontainer:dev
//                                         by .github/workflows/ci.yml on
//                                         merges to main. Never build
//                                         locally.
//        │
//        ▼ (FROM ${BASE_IMAGE})
//
//   .devcontainer/Dockerfile.host-user  ← thin overlay (local build on
//                                         every `mise run up`). Adds
//                                         host-user rename + home staging.
//                                         ≤89 lines enforced by
//                                         hk.pkl:dockerfile_host_user_thin_overlay.
//
// BASE_IMAGE default comes from mise.toml [tasks.up].env. Override
// per-clone via mise.local.toml (see mise.local.toml.example).
//
// ===============================================================
// TWO independent SSH requirements, TWO mechanisms:
//
// (R1) INBOUND shell: `ssh ${USER}@localhost -p 4444` from Mac host
//      opens a shell into the container. Provided by:
//      - `features.ghcr.io/devcontainers/features/sshd` — installs
//        openssh-server. NOTE: the feature's `port`/`username`/`startNow`
//        options are silently dropped (see research report); sshd
//        listens on its hardcoded **2222** internally. External port is
//        `${DEVCONTAINER_SSH_PORT}` (default 4444) via `appPort`.
//      - `postCreateCommand` copies the host user's authorized keys
//        (pre-written by `dotfiles-setup docker initialize-host` on the
//        host from `ssh-add -L`) into `~/.ssh/authorized_keys` so the
//        container sshd can authenticate the Mac user.
//
// (R2) OUTBOUND agent: `ssh -T git@github.com` inside the container
//      reaches the host's launchd SSH agent. Provided by the host-TCP
//      + container-unix-socket proxy pattern in
//      `python/src/dotfiles_setup/docker.py::serve_proxy`. Host half
//      spawned by `initializeCommand`; container half by
//      `postStartCommand` + `postCreateCommand` (idempotent).
//
// Research + rationale:
//   .omc/research/research-20260407-ssh-devcontainer/report.md
// ===============================================================
{
  "name": "dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-${localEnv:DEVCONTAINER_SSH_PORT}",
  "build": {
    "dockerfile": "Dockerfile.host-user",
    "options": [
      "--platform=linux/amd64"
    ],
    "args": {
      "DEVCONTAINER_USERNAME": "${localEnv:USER}",
      "BASE_IMAGE": "${localEnv:BASE_IMAGE}"
    }
  },
  "runArgs": [
    "--name",
    "dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-${localEnv:DEVCONTAINER_SSH_PORT}"
  ],
  "remoteUser": "${localEnv:USER}",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/${localEnv:USER}/.claude,type=bind",
    "source=${localEnv:HOME}/.codex,target=/home/${localEnv:USER}/.codex,type=bind",
    "source=${localEnv:HOME}/.gemini,target=/home/${localEnv:USER}/.gemini,type=bind",
    "source=${localEnv:HOME}/.local/state/dotfiles,target=/tmp/dotfiles-host-state,type=bind",
    "source=dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-mise-user,target=/home/${localEnv:USER}/.local/share/mise,type=volume",
    "source=dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-cargo-user,target=/home/${localEnv:USER}/.cargo,type=volume",
    "source=dotfiles-${localWorkspaceFolderBasename}-${localEnv:USER}-rustup-user,target=/home/${localEnv:USER}/.rustup,type=volume"
  ],
  "containerEnv": {
    "MISE_ARCH": "x64",
    "MISE_OS": "linux",
    "MISE_TRUSTED_CONFIG_PATHS": "/usr/local/share/mise",
    "MISE_OVERRIDE_CONFIG_FILENAMES": "config.toml",
    "MISE_STRICT": "1",
    "DEVCONTAINER": "true",
    "SSH_AUTH_SOCK": "/tmp/dotfiles-ssh-agent.sock"
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {}
  },
  "appPort": ["${localEnv:DEVCONTAINER_SSH_PORT}:2222"],
  "forwardPorts": [2222],
  "updateRemoteUserUID": false,
  "init": true,
  "initializeCommand": "mkdir -p ~/.claude ~/.codex ~/.gemini ~/.local/state/dotfiles && uv run --project python dotfiles-setup docker initialize-host",
  "onCreateCommand": "chezmoi init --apply --source=/workspaces/${localWorkspaceFolderBasename} --no-tty --force && sudo chown -R ${localEnv:USER}:${localEnv:USER} /home/${localEnv:USER}/.local/share/mise /home/${localEnv:USER}/.cargo /home/${localEnv:USER}/.rustup",
  "postCreateCommand": "install -d -m 700 ~/.ssh && install -m 600 /tmp/dotfiles-host-state/authorized_keys ~/.ssh/authorized_keys && ssh-keyscan -t rsa,ecdsa,ed25519 github.com >> ~/.ssh/known_hosts 2>/dev/null && chmod 600 ~/.ssh/known_hosts && uv run --project python dotfiles-setup docker start-container-proxy && scripts/devcontainer-smoke.sh",
  "postStartCommand": "uv run --project python dotfiles-setup docker start-container-proxy",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "mkhl.direnv"
      ]
    }
  }
}
