amends "package://github.com/jdx/hk/releases/download/v1.44.2/hk@1.44.2#/Config.pkl"

import "hk-common.pkl" as common

// Zero-skip policy: fail_fast=false to report ALL issues, not just the first
fail_fast = false

hooks {
  // ==========================================================================
  // PRE-COMMIT: Quality gates before every commit
  // ==========================================================================
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      // --- Shared checks (imported from hk-common.pkl) ---
      ...common.hygiene
      ...common.safety
      ...common.security
      ...common.typos

      // --- Style & Consistency ---
      ["editorconfig-checker"] {}
      ["prettier"] {
        batch = true
      }

      // --- Python: ruff + ty invoked directly via uv so hk uses
      //     python/pyproject.toml config verbatim. Replaces the hk builtin
      //     steps, which silently dropped rules (see Issue #45). ruff + ty
      //     are pinned via python/uv.lock (dev dependency-group).
      //     Order per Astral ruff docs: `ruff check --fix` BEFORE `ruff format`
      //     (lint fixes reorder imports; format then cleans up). ---
      ["py_ruff"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run --project python ruff check python/src tests"
        fix = "uv run --project python ruff check --fix python/src tests"
      }
      ["py_ruff_format"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run --project python ruff format --check python/src tests"
        fix = "uv run --project python ruff format python/src tests"
        depends = List("py_ruff")
      }
      ["python_check_ast"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        batch = true
      }
      ["python_debug_statements"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        batch = true
      }
      ["py_ty"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        check = "uv run --project python ty check python/src tests"
      }

      // --- Zero inline lint suppressions (enforces zero-skip policy) ---
      // Covers: ruff `noqa`, mypy `type: ignore`, ty `ty: ignore`, pylint, bandit `nosec`
      ["no_lint_skip"] {
        glob = List("python/src/**/*.py", "tests/**/*.py", "plugins/**/*.py")
        // --include='*.py' aligns the check with the trigger glob.
        // Without it, `grep -rn` matches markdown docs (e.g.,
        // tests/AGENTS.md) that legitimately quote the suppression
        // tokens while documenting the policy. The intent is to
        // catch suppressions in Python source, not in prose.
        // Scope expanded 2026-04-09 to include plugins/ after a
        // `# noqa: S310` was discovered in a plugin script that had
        // silently escaped enforcement. See feedback memory
        // `feedback_no_inline_lint_suppressions_ever.md`.
        check = "! grep -rn --include='*.py' 'noqa\\|type: ignore\\|ty: ignore\\|pylint: disable\\|nosec' python/src/ tests/ plugins/"
      }

      // --- Dockerfile & Bake ---
      ["hadolint"] {
        glob = List(".devcontainer/Dockerfile")
      }
      ["docker_bake_check"] {
        glob = List("docker-bake.hcl", ".devcontainer/Dockerfile")
        check = "scripts/ensure-docker-up.sh && devcontainer read-configuration --workspace-folder ."
      }

      // --- devcontainer.json 3-layer schema validation ---
      //     Layer 1: biome lint (JSONC parse, duplicate keys)
      //     Layer 2: devcontainer read-configuration (official parser + substitution)
      //     Layer 3: check-jsonschema vs official spec schema URL
      //     Rationale: devcontainer.json is JSONC, so plain JSON tools
      //     choke on trailing commas and comments. The 3-layer pipeline
      //     catches parse errors, substitution failures, AND schema
      //     drift (unknown fields, wrong types, missing required).
      //     See scripts/validate-devcontainer-json.sh for details.
      ["devcontainer_json_validate"] {
        glob = List(".devcontainer/devcontainer.json")
        check = "scripts/validate-devcontainer-json.sh"
      }

      // --- Thin host-user overlay invariant (Principle 1 of devcontainer-build refactor)
      //     Dockerfile.host-user MUST stay <= baseline (79) + 10 = 89 lines.
      //     New capabilities go into Devcontainer Features or devcontainer.json
      //     mounts, NOT new RUN steps in the overlay.
      ["dockerfile_host_user_thin_overlay"] {
        glob = List(".devcontainer/Dockerfile.host-user")
        check = "lines=$(wc -l < .devcontainer/Dockerfile.host-user); [ \"$lines\" -le 89 ] || { echo \"Dockerfile.host-user is $lines lines, cap is 89 (baseline 79 + 10). Add capabilities via Features or devcontainer.json mounts, not RUN steps.\"; exit 1; }"
      }

      // --- TOML ---
      ["taplo_format"] {
        types = List("toml")
        batch = true
      }
      ["taplo"] {
        types = List("toml")
        batch = true
        depends = List("taplo_format")
      }

      // --- YAML ---
      ["yamlfmt"] {
        types = List("yaml")
        batch = true
      }
      ["yamllint"] {
        types = List("yaml")
        batch = true
        depends = List("yamlfmt")
      }

      // --- JSON ---
      ["jq"] {
        types = List("json")
        batch = true
      }

      // --- Pkl ---
      ["pkl"] {
        types = List("pkl")
      }
      ["pkl_format"] {
        types = List("pkl")
      }

      // --- Shell ---
      ["shellcheck"] {
        types = List("shell")
        batch = true
      }
      ["shfmt"] {
        types = List("shell")
        batch = true
        check_first = true
      }

      // --- Markdown ---
      ["markdown_lint"] {
        types = List("markdown")
      }

      // --- GitHub Actions ---
      ["actionlint"] {
        glob = List(".github/workflows/*.yml")
      }
      ["ghalint_workflow"] {
        glob = List(".github/workflows/*.yml")
      }
      ["zizmor"] {
        glob = List(".github/workflows/*.yml")
      }
      ["pinact"] {
        glob = List(".github/workflows/*.yml")
      }
      ["pinact_update"] {
        glob = List(".github/workflows/*.yml")
      }

      // --- HCL ---
      ["hclfmt"] {
        glob = List("**/*.hcl")
      }

      // --- mise config validation ---
      ["mise"] {
        glob = List("**/mise.toml")
      }

      // --- Agent documentation ---
      ["agnix"] {
        check = "agnix ."
        glob = List("CLAUDE.md", "AGENTS.md", ".claude/**/*.md", ".agnix.toml")
      }

      // --- No MCP registration (enforces feedback_no_mcp_registration.md) ---
      //     `claude mcp add` and tracked `.mcp.json` files inflate every
      //     Claude conversation's system prompt with tool schemas. The
      //     sanctioned alternatives are `mcp2cli` (process spawn) and
      //     curl-based llms.txt/.md fetches. See
      //     .claude/rules/research-doc-sources.md and
      //     .claude/skills/mcp2cli/SKILL.md.
      //
      //     Whitelisted paths are the files that legitimately document
      //     the ban (skills, rules, this hk step itself).
      //
      //     Approved exception (2026-04-07): root `.mcp.json` is allowed
      //     to provision OMC default MCP servers (exa, context7, memory,
      //     filesystem) at project scope. Nested `**/.mcp.json` files
      //     remain banned. Tracked in feedback_no_mcp_registration.md;
      //     planned migration: convert to mcp2cli wrappers later.
      ["no_mcp_registration"] {
        check = "! git grep -nE 'claude[[:space:]]+mcp[[:space:]]+add' -- ':!.claude/skills/mcp2cli/SKILL.md' ':!.claude/skills/mintlify/SKILL.md' ':!.claude/rules/research-doc-sources.md' ':!.claude/rules/research-repo-enumeration.md' ':!.claude/CLAUDE.md' ':!AGENTS.md' ':!mise.toml' ':!docs/research/mintlify-catalog.md' ':!hk.pkl' && ! git ls-files '**/.mcp.json' | grep -q ."
      }

      // --- Claude Code memory docs size limit ---
      //     The Claude Code memory docs (code.claude.com/docs/en/memory)
      //     recommend each CLAUDE.md stay "under 200 lines". We enforce
      //     the same limit on AGENTS.md because CLAUDE.md in this repo
      //     is a thin `@AGENTS.md` import stub - the AGENTS.md holds
      //     the content that CLAUDE.md delegates to, so the line budget
      //     effectively lives in AGENTS.md.
      //
      //     Belt-and-suspenders check: claudelint (installed via
      //     mise.toml) has a native size limit check with richer
      //     diagnostics; full integration is tracked in a GH issue
      //     scheduled for post-devcontainer-work review. This awk step
      //     ships immediate enforcement in the meantime.
      ["claude_md_size_limit"] {
        check = "rc=0; for f in $(git ls-files | grep -E '(^|/)(CLAUDE|AGENTS)\\.md$'); do lines=$(wc -l < \"$f\"); if [ \"$lines\" -gt 200 ]; then echo \"$f: $lines lines (max 200 per Claude Code memory docs)\" >&2; rc=1; fi; done; exit $rc"
      }

      // --- No global skill leakage (presence assertion for project-scoped
      //     mcp2cli + mintlify reference skills). Asserts that the
      //     project-local SKILL.md files exist; a commit that deletes them
      //     must also remove this check. Per R3 Architect finding #2, this
      //     replaces a CI parity check that would have been irrelevant on
      //     ephemeral runners. ---
      ["no_global_skill_leakage"] {
        check = "test -f .claude/skills/mcp2cli/SKILL.md && test -f .claude/skills/mintlify/SKILL.md"
      }

    }
  }

  // ==========================================================================
  // COMMIT-MSG: Enforce conventional commit format
  // ==========================================================================
  ["commit-msg"] {
    steps {
      ["check_conventional_commit"] {}
    }
  }

  // ==========================================================================
  // PRE-PUSH: Full test suite before pushing
  // ==========================================================================
  ["pre-push"] {
    steps {
      ["ghcr_publish_prereqs"] {
        exclusive = true
        check = "uv run --project python dotfiles-setup ghcr-check"
      }
      ["test"] {
        exclusive = true
        check = "uv run --project python pytest tests/ -x -q"
      }
    }
  }
}
