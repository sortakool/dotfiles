amends "package://github.com/jdx/hk/releases/download/v1.40.0/hk@1.40.0#/Config.pkl"

// Zero-skip policy: fail_fast=false to report ALL issues, not just the first
fail_fast = false

hooks {
  // ==========================================================================
  // PRE-COMMIT: Quality gates before every commit
  // ==========================================================================
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      // --- File hygiene builtins (auto-detected by step name) ---
      ["trailing_whitespace"] {}
      ["newlines"] {}
      ["mixed_line_ending"] {}
      ["fix_smart_quotes"] {}

      // --- Safety builtins ---
      ["detect_private_key"] {}
      ["check_added_large_files"] {}
      ["check_merge_conflict"] {}
      ["check_case_conflict"] {}
      ["check_symlinks"] {}
      ["check_executables_have_shebangs"] {}
      ["check_byte_order_marker"] {}
      ["no_commit_to_branch"] {}

      // --- Style & Consistency ---
      ["editorconfig-checker"] {}
      ["prettier"] {
        batch = true
      }

      // --- Security ---
      ["gitleaks"] {
        batch = true
      }
      ["betterleaks"] {
        batch = true
      }

      // --- Typo detection ---
      ["typos"] {
        batch = true
      }

      // --- Python: ruff + ty (keep glob — types would match .py.tmpl templates) ---
      ["ruff_format"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        batch = true
      }
      ["ruff"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        batch = true
        check_first = true
      }
      ["python_check_ast"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        batch = true
      }
      ["python_debug_statements"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
        batch = true
      }
      ["ty"] {
        glob = List("python/src/**/*.py", "tests/**/*.py")
      }

      // --- Dockerfile & Bake ---
      ["hadolint"] {
        glob = List(".devcontainer/Dockerfile")
      }
      ["docker_bake_check"] {
        glob = List("docker-bake.hcl", ".devcontainer/Dockerfile")
        check = "devcontainer read-configuration --workspace-folder ."
      }

      // --- TOML ---
      ["taplo_format"] {
        types = List("toml")
        batch = true
      }
      ["taplo"] {
        types = List("toml")
        batch = true
        depends = List("taplo_format")
      }

      // --- YAML ---
      ["yamlfmt"] {
        types = List("yaml")
        batch = true
      }
      ["yamllint"] {
        types = List("yaml")
        batch = true
        depends = List("yamlfmt")
      }

      // --- JSON ---
      ["jq"] {
        types = List("json")
        batch = true
      }

      // --- Pkl ---
      ["pkl"] {
        types = List("pkl")
      }
      ["pkl_format"] {
        types = List("pkl")
      }

      // --- Shell ---
      ["shellcheck"] {
        types = List("shell")
        batch = true
      }
      ["shfmt"] {
        types = List("shell")
        batch = true
        check_first = true
      }

      // --- Markdown ---
      ["markdown_lint"] {
        types = List("markdown")
      }

      // --- GitHub Actions ---
      ["actionlint"] {
        glob = List(".github/workflows/*.yml")
      }
      ["ghalint_workflow"] {
        glob = List(".github/workflows/*.yml")
      }
      ["zizmor"] {
        glob = List(".github/workflows/*.yml")
      }
      ["pinact"] {
        glob = List(".github/workflows/*.yml")
      }

      // --- HCL ---
      ["hclfmt"] {
        glob = List("**/*.hcl")
      }

      // --- mise config validation ---
      ["mise"] {
        glob = List("**/mise.toml")
      }
    }
  }

  // ==========================================================================
  // COMMIT-MSG: Enforce conventional commit format
  // ==========================================================================
  ["commit-msg"] {
    steps {
      ["check_conventional_commit"] {}
    }
  }

  // ==========================================================================
  // PRE-PUSH: Full test suite before pushing
  // ==========================================================================
  ["pre-push"] {
    steps {
      ["ghcr_publish_prereqs"] {
        exclusive = true
        check = "uv run --directory python dotfiles-setup ghcr-check"
      }
      ["test"] {
        exclusive = true
        check = "uv run pytest tests/ -x -q"
      }
    }
  }
}
