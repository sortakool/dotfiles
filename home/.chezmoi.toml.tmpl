{{- /* Multi-machine config — uses the built-in chezmoi.os fact as the canonical
       host/container discriminator. Mac host = "darwin", devcontainer = "linux".
       No third target exists in this repo (CI runners are linux but the
       devcontainer-only mise overlay still applies — they are simulating the
       container build).

       This is the canonical chezmoi pattern per
       https://www.chezmoi.io/user-guide/manage-machine-to-machine-differences/

       Previously this template invented a custom `is_container` data variable
       fed by REMOTE_CONTAINERS / CODESPACES / DEVCONTAINER env-var detection.
       That was reinvention and caused real bugs on stale host configs. See
       memory feedback_use_tool_builtins.md and the C10 commit body. */ -}}
{{- $isCI := ne (env "CI") "" -}}
{{- $isInteractive := and (eq .chezmoi.os "darwin") (not $isCI) stdinIsATTY -}}

{{- /* Defaults — overridden by prompts when interactive on Mac. NOTE: Changes
       to this file require `chezmoi init` on existing machines. */ -}}
{{- $isDevComputer := false -}}
{{- $isPersonal := false -}}
{{- $isEphemeral := eq .chezmoi.os "linux" -}}

{{- if $isInteractive -}}
{{-   $isDevComputer = promptBoolOnce . "is_dev_computer" "Is this a development computer" false -}}
{{-   $isPersonal = promptBoolOnce . "is_personal" "Is this a personal machine" false -}}
{{-   $isEphemeral = promptBoolOnce . "is_ephemeral" "Is this an ephemeral environment" false -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   $isDevComputer = true -}}
{{- end -}}

[data]
    is_dev_computer = {{ $isDevComputer }}
    is_personal = {{ $isPersonal }}
    is_ephemeral = {{ or $isEphemeral $isCI }}
    is_ci = {{ $isCI }}

[scriptEnv]
    PATH = {{ list (joinPath .chezmoi.homeDir ".local/bin") (joinPath (env "MISE_DATA_DIR" | default (joinPath .chezmoi.homeDir ".local/share/mise")) "shims") "/usr/local/bin" "/usr/bin" "/bin" "/sbin" | join ":" | quote }}

[git]
    autoCommit = false
    commitMessageTemplate = "chezmoi: update {{ .chezmoi.os }}/{{ .chezmoi.arch }}"

[diff]
    pager = "delta"
