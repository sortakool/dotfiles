[tools]
# Python comes from Mise's registries
python = "3.14.3"
chezmoi = "2.70.0"
uv = "0.11.0"
pixi = "0.66.0"
bun = "1.3.11"
node = "25.8.2"
go = "1.26.1"
rust = "1.94.0"
zig = "0.15.2"
bats = "1.13.0"
fzf = "0.70.0"
ripgrep = "15.1.0"
fd = "10.4.2"
bat = "0.26.1"
# Git hooks & linting tools
hk = "1.39.0"
hadolint = "2.12.0"
shellcheck = "0.10.0"
shfmt = "3.11.0"
taplo = "0.9.3"
actionlint = "1.7.7"
typos = "1.32.0"
yamllint = "1.37.0"
jq = "1.7.1"
# AI CLIs
"npm:@google/gemini-cli" = "0.35.0"
"npm:@openai/codex" = "0.116.0"

[settings]
experimental = true
auto_install = true
asdf_compat = true

[env]
# Enforce system toolchains for low-level builds
CC = "gcc"
CXX = "g++"
# hk: use built-in Rust pkl evaluator (no pkl CLI dependency)
HK_PKL_BACKEND = "pklr"
# hk: enable mise integration
HK_MISE = "1"
