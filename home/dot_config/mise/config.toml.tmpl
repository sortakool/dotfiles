# Dotfiles environment tools — baked into the Docker image
# These are pre-installed globally in /opt/mise during the build stage

[tools]
# Core runtimes
python = "latest"
uv = "latest"
node = "latest"
bun = "latest"
go = "latest"
rust = "latest"
zig = "latest"
pixi = "latest"
java = "latest"
deno = "latest"
ruby = "latest"
cargo-binstall = "latest"
# Dotfiles management
chezmoi = "latest"
# Git hooks & linting
hk = "latest"
hadolint = "latest"
shellcheck = "latest"
shfmt = "latest"
taplo = "latest"
actionlint = "latest"
typos = "latest"
yamllint = "latest"
yamlfmt = "latest"
yq = "latest"
ghalint = "latest"
jq = "latest"
# CLI utilities
fzf = "latest"
ripgrep = "latest"
fd = "latest"
bat = "latest"
vivid = "latest"
"github:cli/cli" = "latest"
# AI CLIs
"npm:@google/gemini-cli" = "latest"
"npm:@openai/codex" = "latest"

[settings]
experimental = true
auto_install = true
asdf_compat = true
lockfile = true
jobs = 1
npm.package_manager = "bun"
pipx.uvx = true
cargo.binstall = true
cargo.binstall_only = false
conda.channel = "conda-forge"
github.github_attestations = true
github.slsa = true
python.uv_venv_auto = "source"

[settings.status]
show_tools = true
missing_tools = "always"

[env]
# Build toolchain
CC = "gcc"
CXX = "g++"
HK_PKL_BACKEND = "pkl"  # "pkl" (not pklr) required for import/spread in hk-common.pkl
HK_MISE = "1"
# rustup warns during non-interactive installs unless PATH checking is explicitly skipped
RUSTUP_INIT_SKIP_PATH_CHECK = "yes"
# Global mise paths
MISE_ARCH = "x64"
MISE_OS = "linux"

[tasks."setup:tools"]
description = "Install all tools and reshim"
run = "mise install -y && mise reshim -f"

[tasks."setup:gpg"]
description = "Import GPG keys"
run = """
for keyfile in ~/.config/git/*.asc; do
    [ -f "$keyfile" ] || continue
    gpg --import "$keyfile" 2>/dev/null || true
done
"""
