[tools]
# Python comes from Mise's registries
python = "3.14.3"
chezmoi = "2.70.0"
uv = "0.11.0"
pixi = "0.66.0"
bun = "1.3.11"
node = "25.8.2"
go = "1.26.1"
rust = "1.94.0"
zig = "0.15.2"
bats = "1.13.0"
fzf = "0.70.0"
ripgrep = "15.1.0"
fd = "10.4.2"
bat = "0.26.1"
"npm:@google/gemini-cli" = "0.35.0"
"npm:@openai/codex" = "0.116.0"

[settings]
experimental = true
auto_install = true
asdf_compat = true

[env]
# Enforce system toolchains for low-level builds
CC = "gcc"
CXX = "g++"
