# Dotfiles environment tools — baked into the Docker image via install.sh
# These are Build Type 2 tools: the full dev toolchain

[tools]
# Core runtimes
python = "3.14.3"
uv = "0.11.2"
node = "25.8.2"
go = "1.26.1"
rust = "1.94.1"
zig = "0.15.2"
bun = "1.3.11"
pixi = "0.66.0"
# Dotfiles management
chezmoi = "2.70.0"
# Git hooks & linting (also in project mise.toml, pinned here for image reproducibility)
hk = "1.39.0"
pkl = "0.31.1"
hadolint = "2.14.0"
shellcheck = "0.11.0"
shfmt = "3.13.0"
taplo = "0.10.0"
actionlint = "1.7.11"
typos = "1.44.0"
yamllint = "1.38.0"
yamlfmt = "0.18.0"
yq = "4.52.5"
ghalint = "1.0.0"
jq = "1.8.1"
# CLI utilities
bats = "1.13.0"
fzf = "0.70.0"
ripgrep = "15.1.0"
fd = "10.4.2"
bat = "0.26.1"
# AI CLIs
"npm:@google/gemini-cli" = "0.35.3"
"npm:@openai/codex" = "0.117.0"

[settings]
experimental = true
auto_install = true
asdf_compat = true
lockfile = true

[settings.status]
show_tools = true
missing_tools = "always"

[env]
# Per-tool paths: Dockerfile ENV provides /opt/ values in containers;
# Tera default() provides bare-metal fallback to ~/.local/share/*.
CARGO_HOME = "{{ "{{ env.CARGO_HOME | default(value=env.HOME ~ '/.local/share/cargo') }}" }}"
RUSTUP_HOME = "{{ "{{ env.RUSTUP_HOME | default(value=env.HOME ~ '/.local/share/rustup') }}" }}"
NPM_CONFIG_PREFIX = "{{ "{{ env.NPM_CONFIG_PREFIX | default(value=env.HOME ~ '/.local/share/npm') }}" }}"
NPM_CONFIG_CACHE = "{{ "{{ env.NPM_CONFIG_CACHE | default(value=env.HOME ~ '/.cache/npm') }}" }}"
GOPATH = "{{ "{{ env.GOPATH | default(value=env.HOME ~ '/.local/share/go') }}" }}"
GOBIN = "{{ "{{ env.GOBIN | default(value=env.HOME ~ '/.local/share/go/bin') }}" }}"
GOMODCACHE = "{{ "{{ env.GOMODCACHE | default(value=env.HOME ~ '/.cache/go/mod') }}" }}"
GOCACHE = "{{ "{{ env.GOCACHE | default(value=env.HOME ~ '/.cache/go/build') }}" }}"

# Build toolchain
CC = "gcc"
CXX = "g++"
HK_PKL_BACKEND = "pklr"
HK_MISE = "1"
